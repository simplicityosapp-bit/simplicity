# Copy to .env.local (gitignored) and fill in. Both are PUBLIC config — the anon
# key is the same one shipped in the web bundle (safe to embed in a mobile build).
# Expo inlines EXPO_PUBLIC_* variables at bundle time.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Sign-In (native). Use the SAME Web OAuth client ID the web app and the
# Supabase Google provider already use — NOT the Android/iOS client ID. On
# Android the ID token's audience is this Web client ID; the Android OAuth client
# (package + SHA-1, in Google Cloud Console) only authorizes the app to Google.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-oauth-client-id.apps.googleusercontent.com
